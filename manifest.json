{
  "manifest_version": 3,
  "name": "Tab Scroll Switcher",
  "version": "1.0.0",
  "description": "Switch tabs by middle-click scrolling over the tab bar",
  "permissions": ["tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "run_at": "document_end"
  }]
}